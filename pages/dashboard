<!-- pages/dashboard.html -->
<div class="container-fluid p-0">
  <!-- هدر صفحه داخلی (Title & Actions) -->
  <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
    <div>
      <h4 class="mb-1 fw-bold text-dark">پیشخوان سیستم</h4>
      <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-0" style="font-size: 0.85rem;">
          <li class="breadcrumb-item"><a href="#dashboard" class="text-success text-decoration-none">خانه</a></li>
          <li class="breadcrumb-item active" aria-current="page">داشبورد</li>
        </ol>
      </nav>
    </div>
    <!-- دکمه عملیاتی سریع در صورت نیاز -->
    <div>
      <button class="btn btn-success btn-custom py-2 px-3 d-flex align-items-center gap-2" onclick="location.reload();">
        <i class="bi bi-arrow-clockwise"></i>
        <span>به‌روزرسانی داده‌ها</span>
      </button>
    </div>
  </div>

  <!-- بخش کارت‌های آمار سریع (Stat Cards) -->
  <div class="row g-4 mb-4">
    <!-- کارت اول -->
    <div class="col-12 col-sm-6 col-xl-3">
      <div class="card border-0 rounded-4 shadow-sm h-100" style="border-right: 5px solid var(--primary-color) !important;">
        <div class="card-body d-flex align-items-center justify-content-between p-4">
          <div>
            <p class="text-muted mb-1 fw-bold" style="font-size: 0.85rem;">کاربران فعال</p>
            <h3 class="mb-0 fw-bold" id="stat-users-count">...</h3>
          </div>
          <div class="rounded-3 bg-success bg-opacity-10 p-3 text-success d-flex align-items-center justify-content-center" style="width: 50px; height: 50px;">
            <i class="bi bi-people-fill fs-4"></i>
          </div>
        </div>
      </div>
    </div>

    <!-- کارت دوم -->
    <div class="col-12 col-sm-6 col-xl-3">
      <div class="card border-0 rounded-4 shadow-sm h-100" style="border-right: 5px solid var(--secondary-color) !important;">
        <div class="card-body d-flex align-items-center justify-content-between p-4">
          <div>
            <p class="text-muted mb-1 fw-bold" style="font-size: 0.85rem;">تراکنش‌های امروز</p>
            <h3 class="mb-0 fw-bold" id="stat-transactions-count">...</h3>
          </div>
          <div class="rounded-3 bg-primary bg-opacity-10 p-3 text-primary d-flex align-items-center justify-content-center" style="width: 50px; height: 50px;">
            <i class="bi bi-wallet2 fs-4"></i>
          </div>
        </div>
      </div>
    </div>

    <!-- کارت سوم -->
    <div class="col-12 col-sm-6 col-xl-3">
      <div class="card border-0 rounded-4 shadow-sm h-100" style="border-right: 5px solid #ffc107 !important;">
        <div class="card-body d-flex align-items-center justify-content-between p-4">
          <div>
            <p class="text-muted mb-1 fw-bold" style="font-size: 0.85rem;">درخواست‌های معلق</p>
            <h3 class="mb-0 fw-bold" id="stat-pending-requests">...</h3>
          </div>
          <div class="rounded-3 bg-warning bg-opacity-10 p-3 text-warning d-flex align-items-center justify-content-center" style="width: 50px; height: 50px;">
            <i class="bi bi-hourglass-split fs-4"></i>
          </div>
        </div>
      </div>
    </div>

    <!-- کارت چهارم -->
    <div class="col-12 col-sm-6 col-xl-3">
      <div class="card border-0 rounded-4 shadow-sm h-100" style="border-right: 5px solid #17a2b8 !important;">
        <div class="card-body d-flex align-items-center justify-content-between p-4">
          <div>
            <p class="text-muted mb-1 fw-bold" style="font-size: 0.85rem;">بازدید کل</p>
            <h3 class="mb-0 fw-bold" id="stat-total-visits">...</h3>
          </div>
          <div class="rounded-3 bg-info bg-opacity-10 p-3 text-info d-flex align-items-center justify-content-center" style="width: 50px; height: 50px;">
            <i class="bi bi-eye-fill fs-4"></i>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- جدول آخرین فعالیت‌ها -->
  <div class="card border-0 rounded-4 shadow-sm">
    <div class="card-header bg-white border-0 pt-4 pb-0 px-4 d-flex justify-content-between align-items-center">
      <h5 class="fw-bold mb-0 text-dark">آخرین فعالیت‌های کاربران</h5>
      <span class="badge bg-success bg-opacity-10 text-success rounded-pill px-3 py-2 fw-bold" style="font-size: 0.75rem;">به‌روز شده</span>
    </div>
    <div class="card-body px-4 pb-4">
      <div class="table-responsive">
        <table class="table align-middle table-hover mb-0">
          <thead class="table-light">
            <tr>
              <th class="border-0 text-muted py-3" style="font-size: 0.85rem;">کاربر</th>
              <th class="border-0 text-muted py-3" style="font-size: 0.85rem;">عملیات انجام شده</th>
              <th class="border-0 text-muted py-3" style="font-size: 0.85rem;">تاریخ و زمان</th>
              <th class="border-0 text-muted py-3" style="font-size: 0.85rem;">وضعیت تراکنش</th>
            </tr>
          </thead>
          <tbody id="dashboard-recent-activities">
            <!-- ردیف‌های جدول به صورت پویا با جاوااسکریپت پر می‌شوند -->
            <tr>
              <td colspan="4" class="text-center py-4 text-muted">در حال دریافت اطلاعات...</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>
